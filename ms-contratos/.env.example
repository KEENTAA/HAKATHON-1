# ============================================================================
# .env.example - Variables de Entorno para ms-contratos
# Copiar a .env y ajustar valores según ambiente
# ============================================================================

# ========== Base de Datos PostgreSQL ==========
DB_USER=arca_user
DB_PASSWORD=arca_password
DB_HOST=ms_contratos_db
DB_PORT=5432
DB_NAME=db_contratos

# ========== Aplicación FastAPI ==========
APP_NAME=ms-contratos
APP_VERSION=1.0.0
APP_PORT=8002
DEBUG=True

# ========== Logging ==========
LOG_LEVEL=INFO
